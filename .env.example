# Discord — all on synapz_org server
DISCORD_BOT_TOKEN=
SYNAPZ_GUILD_ID=                 # synapz_org server ID
SYNAPZ_DROPBOX_CHANNEL_ID=      # #dropbox — forward messages here for extraction
SYNAPZ_FEED_CHANNEL_ID=         # #agent-feed — digest notifications
SYNAPZ_APPROVALS_CHANNEL_ID=    # #approvals — PR review notifications
SYNAPZ_COMMANDS_CHANNEL_ID=     # #commands — bot commands

# Claude (uses claude CLI with Max subscription — no API key needed)
# For fallback/remote: set OPENROUTER_API_KEY for when laptop is off
OPENROUTER_API_KEY=              # optional fallback

# GitHub
GITHUB_TOKEN=                    # PAT with repo scope
